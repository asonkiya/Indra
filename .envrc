SESSION="indra"

# Activate mise-managed toolchain (puts go in PATH for this shell)
eval "$(mise env -s bash)"

# Only create the session if it doesn't already exist
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  # Window 1: build / run node
  tmux new-session -d -s "$SESSION" -n "run" -c "$PWD"
  tmux send-keys -t "$SESSION:run" "make deps && make build" Enter

  # Window 2: nvim on the node entrypoint
  tmux new-window -t "$SESSION" -n "edit" -c "$PWD"
  tmux send-keys -t "$SESSION:edit" "nvim cmd/indra/main.go" Enter

  # Window 3: tests (watch mode via entr if available, else plain)
  tmux new-window -t "$SESSION" -n "test" -c "$PWD"
  tmux send-keys -t "$SESSION:test" "make test" Enter

  # Window 4: claude
  tmux new-window -t "$SESSION" -n "claude" -c "$PWD"
  tmux send-keys -t "$SESSION:claude" "claude --continue" Enter
fi

# Attach or switch to the session
if [[ -z "$TMUX" ]]; then
  tmux attach -t "$SESSION"
else
  tmux switch-client -t "$SESSION"
fi
