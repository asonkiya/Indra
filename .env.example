# Docker Compose — Bootstrap node
# Get the bootstrap node's peer ID by running:
#   docker compose run --rm bootstrap --data=/data
# and copying the "Peer ID:" line printed on startup.
BOOTSTRAP_PEER_ID=12D3KooW...

# Push notification relay (APNs)
# Generate a .p8 key in Apple Developer → Keys → APNs
APNS_P8_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_TOPIC=com.yourcompany.indra
APNS_PROD=false
